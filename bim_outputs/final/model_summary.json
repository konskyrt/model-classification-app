{
  "experiment": "exp3_huge_signature_mitigation",
  "model_name": "LightGBM",
  "n_estimators": 800,
  "learning_rate": 0.04,
  "num_leaves": 63,
  "min_child_samples": 8,
  "reg_alpha": 0.2,
  "reg_lambda": 0.2,
  "class_weight": "balanced",
  "random_state": 42,
  "accuracy": 0.8846,
  "macro_f1": 0.6375,
  "weighted_f1": 0.8894,
