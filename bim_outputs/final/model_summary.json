      "area_min",
      "area_std",
      "area_sum",
      "area_sum_log1p",
      "length_mean",
      "length_max",
      "length_min",
      "length_std",
      "length_sum",
      "length_sum_log1p",
      "width_mean",
      "width_max",
      "width_min",
      "width_std",
      "width_sum",
      "width_sum_log1p",
      "height_mean",
      "height_max",
      "height_min",
      "height_std",
      "height_sum",
      "height_sum_log1p",
      "object_count",
      "objectcount_log1p",
      "is_huge_signature"
